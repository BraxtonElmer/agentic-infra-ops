# Copy to .env and fill in your values

# LLM — Groq (free tier: console.groq.com, no credit card)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# GitHub (optional — for pipeline integration)
# Get at: github.com/settings/tokens → "Fine-grained tokens" → Actions: read
# Scope needed: Actions (read), Contents (read) for each repo you add
GITHUB_TOKEN=github_pat_...

# Server label (how this machine shows in the dashboard)
LOCAL_SERVER_NAME=ops-server

# Database (default: SQLite file in backend dir — no setup needed)
DATABASE_URL=sqlite:///./axiom.db
